# ── Server ──────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── Database ────────────────────────────────────────────
# MongoDB Atlas connection string (or local: mongodb://localhost:27017/jobhunt)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ── Authentication ──────────────────────────────────────
# Random string used to sign JWT tokens — make this long and random
JWT_SECRET=change_me_to_a_random_secret_string

# ── AI Providers ────────────────────────────────────────
# Google Gemini (primary) — get a key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Cohere (automatic fallback) — get a key at https://cohere.com
COHERE_API_KEY=your_cohere_api_key_here

# ── CORS Configuration ──────────────────────────────────
# Comma-separated list of allowed frontend URLs in production
FRONTEND_URL=https://your-app.vercel.app

# ── Development ─────────────────────────────────────────
# Set to 'true' to bypass JWT auth in development (auto-uses first user in DB)
# NEVER set this in production!
# DEV_BYPASS_AUTH=true
